{
  "version": 2,
  "builds": [
    {
      "src": "CadastroUsuarios/pom.xml",
      "use": "@vercel/java"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "JAVA_VERSION": "17",
    "MAVEN_CACHE_BUCKET": ""
  },
  "buildCommand": "cd CadastroUsuarios && mvn clean package -DskipTests -Dquarkus.package.type=uber-jar",
  "outputDirectory": "CadastroUsuarios/target"
}